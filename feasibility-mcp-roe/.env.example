# Copy to .env, then `source .env` before running.
#
# AUTH: NO API KEY NEEDED.
# Authentication is handled by Claude Code (bundled with claude-agent-sdk).
# Run `claude /login` once to authenticate via your Claude account / Team seat.
# After login, the SDK auto-picks up auth (apiKeySource: 'none').

# Model — default Haiku 4.5 for parity with TH3 paper's GPT-4o-mini.
# Swap to claude-opus-4-8 for the ceiling benchmark.
export CLAUDE_MODEL="claude-haiku-4-5"

# Audit log path — one CSV per blue agent per run.
export AUDIT_LOG_PATH="./audit_blue_agent_4.csv"
